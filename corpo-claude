#!/usr/bin/env bash
set -euo pipefail

# ── Bootstrap ──────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "$SCRIPT_DIR/lib/utils.sh"

# ── Usage ──────────────────────────────────────────────────────

usage() {
  cat <<EOF
corpo-claude $CORPO_VERSION — Standardize Claude Code configuration across teams

Usage:
  corpo-claude <command> <subcommand> [options]

Commands:
  skill search [query]         Search available skills across registries
  skill install <name>         Install a skill (prompts for scope)
  skill uninstall <name>       Remove an installed skill
  skill list                   Show installed skills

  profile search [query]       Search available profiles across registries
  profile install [--profile]  Apply a profile (prompts for scope)
  profile list                 Show available local profiles
  profile preview              Show what a profile would write (read-only)

  fork [task.md]               Fork tasks into parallel sandboxed agents (Docker Desktop 4.50+)
  fork status                  Show running/completed forks
  fork attach <name>           Attach to a running sandbox
  fork review [name]           Review and merge/reject completed forks
  fork clean                   Remove finished worktrees

  registry add <owner/repo>    Add a registry
  registry remove <owner/repo> Remove a registry
  registry list                Show all registries

Options:
  --profile <name>   Profile(s) to apply (can be repeated; omit for interactive picker)
  --global           Skip scope prompt, use user scope (~/.claude/)
  --project          Skip scope prompt, use project scope (./.claude/)
  --refresh          Bypass cache when searching remote registries
  --help, -h         Show this help message
  --version, -v      Show version

Examples:
  corpo-claude skill search
  corpo-claude skill install pdf
  corpo-claude skill install multi-agent-team --project
  corpo-claude skill list
  corpo-claude profile search
  corpo-claude profile install --profile usize
  corpo-claude profile install --profile usize --global
  corpo-claude profile preview --profile usize
  corpo-claude fork .tasks/refactor-auth.md
  corpo-claude fork status
  corpo-claude fork attach refactor-auth
  corpo-claude fork review
  corpo-claude fork clean
  corpo-claude registry add myorg/claude-config
EOF
}

# ── Main ───────────────────────────────────────────────────────

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  case "${1:-}" in
    --help|-h)
      usage
      exit 0
      ;;
    --version|-v)
      echo "corpo-claude $CORPO_VERSION"
      exit 0
      ;;
  esac

  check_all_dependencies

  source "$SCRIPT_DIR/lib/profiles.sh"
  source "$SCRIPT_DIR/lib/preview.sh"
  source "$SCRIPT_DIR/lib/init.sh"
  source "$SCRIPT_DIR/lib/registry.sh"
  source "$SCRIPT_DIR/lib/skills.sh"
  source "$SCRIPT_DIR/lib/fork.sh"

  local cmd="$1"
  shift

  case "$cmd" in
    skill)
      cmd_skill "$@"
      ;;
    profile)
      cmd_profile "$@"
      ;;
    fork)
      cmd_fork "$@"
      ;;
    registry)
      cmd_registry "$@"
      ;;
    *)
      error "Unknown command: $cmd"
      echo ""
      usage
      exit 1
      ;;
  esac
}

main "$@"
